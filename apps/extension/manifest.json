{
  "manifest_version": 3,
  "name": "Browser Automation Agent",
  "version": "0.1.0",
  "description": "AI browser agent with approvals, backed by Next.js + Postgres",
  "permissions": ["sidePanel", "scripting", "tabs", "storage", "activeTab"],
  "host_permissions": ["http://localhost:3000/*", "http://127.0.0.1:3000/*", "<all_urls>"],
  "background": {
    "service_worker": "src/background.ts",
    "type": "module"
  },
  "action": {
    "default_title": "Open agent panel"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content.ts"],
      "run_at": "document_idle"
    }
  ]
}
